# Supabase Postgres (Q4 와 동일 DB 사용 — 테이블명 cm_* 로 분리)
PGHOST=aws-1-us-east-1.pooler.supabase.com
PGPORT=6543
PGUSER=postgres.YOUR_PROJECT_REF
PGPASSWORD=YOUR_DB_PASSWORD
PGDATABASE=postgres

# JWT
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=7d

# Server
PORT=3001

# ImageKit — 상품 등록 이미지 업로드용 (Q1 키 재사용 가능)
IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxxxxxxxxxxx
IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxxxxxxxxxxxxxx
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/yourname

# 단계 7 부터 사용
